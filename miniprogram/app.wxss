page {
  background: #F5F7FA;
  color: #1F2937;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  font-size: 28rpx;
}

.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 40rpx;
  box-sizing: border-box;
}

.page.with-bottom-bar {
  padding-bottom: 170rpx;
}

.card {
  background: #ffffff;
  border: 1rpx solid #E5E7EB;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.05);
}

.title {
  font-size: 44rpx;
  font-weight: 800;
  letter-spacing: 0;
  margin-bottom: 10rpx;
}

.subtle {
  color: #667085;
  font-size: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 18rpx;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 12rpx 0;
}

.primary,
.secondary,
.danger {
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 700;
  margin: 0;
  border: 0;
  line-height: 2.7;
}

.primary {
  color: #ffffff;
  background: #00A86B;
}

.secondary {
  color: #07865A;
  background: #EAF8F2;
}

.danger {
  color: #ffffff;
  background: #FF4D4F;
}

.button-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.tag {
  display: inline-block;
  color: #07865A;
  background: #EAF8F2;
  border-radius: 999rpx;
  padding: 6rpx 16rpx;
  font-size: 22rpx;
}

.empty {
  color: #6b7280;
  text-align: center;
  padding: 48rpx 0;
}

.metric {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 22rpx;
  border-radius: 16rpx;
  background: #f8fafc;
}

.metric-value {
  color: #1F2937;
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.1;
}

.metric-label {
  color: #667085;
  font-size: 23rpx;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  padding: 18rpx 24rpx 42rpx;
  background: rgba(255, 255, 255, 0.96);
  border-top: 1rpx solid #E5E7EB;
  box-shadow: 0 -10rpx 28rpx rgba(15, 23, 42, 0.08);
  box-sizing: border-box;
}

.page-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.page-title {
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.2;
}

.pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  color: #07865A;
  font-size: 23rpx;
  font-weight: 800;
  background: #EAF8F2;
}

.thin-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #EEF0F2;
}

.thin-row:last-child {
  border-bottom: 0;
}

.row-title {
  color: #1F2937;
  font-weight: 800;
}

.row-subtitle {
  margin-top: 6rpx;
  color: #667085;
  font-size: 23rpx;
  line-height: 1.45;
}

.progress-track {
  height: 14rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #E5E7EB;
}

.progress-fill {
  height: 100%;
  min-width: 8rpx;
  border-radius: 999rpx;
  background: #00A86B;
}
