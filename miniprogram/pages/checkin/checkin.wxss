.checkin-hero {
  padding: 30rpx;
  margin-bottom: 24rpx;
  border-radius: 24rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #00A86B 0%, #35CDA0 100%);
  box-shadow: 0 18rpx 42rpx rgba(0, 168, 107, 0.22);
  box-sizing: border-box;
}

.hero-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.hero-kicker {
  font-size: 24rpx;
  opacity: 0.9;
}

.hero-title {
  margin-top: 10rpx;
  font-size: 54rpx;
  font-weight: 900;
  line-height: 1.1;
}

.hero-badge {
  flex: 0 0 auto;
  min-width: 112rpx;
  height: 52rpx;
  line-height: 52rpx;
  border-radius: 999rpx;
  color: #07865A;
  font-size: 23rpx;
  font-weight: 800;
  text-align: center;
  background: rgba(255, 255, 255, 0.9);
}

.hero-subtitle {
  margin-top: 16rpx;
  font-size: 25rpx;
  opacity: 0.9;
}

.hero-progress-wrap {
  padding: 0 2rpx;
  margin-top: 24rpx;
}

.hero-progress {
  width: 100%;
  background: rgba(255, 255, 255, 0.32);
}

.hero-progress .progress-fill {
  background: #ffffff;
}

.hero-button {
  display: block;
  width: 70%;
  min-width: 280rpx;
  margin: 30rpx auto 0;
  color: #00A86B;
  background: #ffffff;
  box-sizing: border-box;
}

.goal-card {
  position: relative;
  overflow: hidden;
  padding: 28rpx;
  border: 1rpx solid rgba(0, 168, 107, 0.12);
  background: linear-gradient(180deg, #ffffff 0%, #f3fbf7 100%);
}

.goal-card::before {
  content: "";
  position: absolute;
  right: -80rpx;
  top: -90rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 999rpx;
  background: rgba(0, 168, 107, 0.09);
}

.goal-card-head {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.goal-hint {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 23rpx;
  line-height: 1.35;
}

.goal-status {
  flex: 0 0 auto;
  padding: 9rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 900;
}

.goal-status-open {
  color: #047857;
  background: #d1fae5;
}

.goal-status-locked {
  color: #92400e;
  background: #fef3c7;
}

.goal-metrics {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 24rpx;
}

.goal-metrics > view {
  padding: 20rpx 10rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.78);
  box-shadow: 0 8rpx 22rpx rgba(15, 23, 42, 0.04);
  text-align: center;
}

.goal-number {
  color: #0f172a;
  font-size: 34rpx;
  font-weight: 950;
  line-height: 1.1;
}

.goal-label {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 21rpx;
  font-weight: 700;
}

.goal-progress-card {
  position: relative;
  z-index: 1;
  margin-top: 22rpx;
  padding: 20rpx;
  border-radius: 20rpx;
  background: #ffffff;
}

.goal-progress {
  width: 100%;
  height: 14rpx;
}

.goal-progress-copy {
  margin-top: 12rpx;
  color: #475569;
  font-size: 23rpx;
  font-weight: 750;
}

.goal-editor {
  position: relative;
  z-index: 1;
  margin-top: 22rpx;
}

.goal-editor-disabled {
  opacity: 0.62;
}

.goal-input-wrap {
  display: flex;
  align-items: center;
  gap: 14rpx;
  height: 88rpx;
  padding: 0 20rpx;
  border: 2rpx solid #d1fae5;
  border-radius: 22rpx;
  color: #64748b;
  background: #ffffff;
  font-size: 24rpx;
  font-weight: 800;
  box-sizing: border-box;
}

.goal-input-wrap input {
  flex: 1;
  height: 72rpx;
  color: #0f172a;
  font-size: 34rpx;
  font-weight: 950;
  text-align: center;
}

.goal-preset-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  margin-top: 16rpx;
}

.goal-preset {
  min-height: 64rpx;
  line-height: 64rpx;
  border-radius: 18rpx;
  color: #07865A;
  background: #eaf8f2;
  font-size: 24rpx;
  font-weight: 900;
  text-align: center;
}

.goal-preset-active {
  color: #ffffff;
  background: #00A86B;
  box-shadow: 0 10rpx 20rpx rgba(0, 168, 107, 0.18);
}

.goal-save-button {
  width: 100%;
  min-height: 84rpx;
  margin-top: 16rpx;
  border-radius: 22rpx;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 84rpx;
  box-sizing: border-box;
}

.calendar-week,
.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8rpx;
}

.calendar-week {
  margin: 22rpx 0 12rpx;
  color: #667085;
  font-size: 23rpx;
  text-align: center;
}

.calendar-day {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 70rpx;
  height: 70rpx;
  margin: 0 auto;
  border-radius: 999rpx;
  color: #475467;
  font-weight: 800;
  background: #F5F7FA;
  box-sizing: border-box;
}

.calendar-empty {
  background: transparent;
}

.calendar-checked {
  color: #ffffff;
  background: #4CCDB2;
}

.calendar-today {
  border: 3rpx solid #00A86B;
}
