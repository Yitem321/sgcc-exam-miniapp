<view class="page">
  <view class="page-head">
    <view>
      <view class="page-title">我的</view>
      <view class="subtle">{{isLoggedIn ? '学习记录已可同步' : '免费刷题，无需登录'}}</view>
    </view>
    <view class="pill">{{isLoggedIn ? '已登录' : '未登录'}}</view>
  </view>

  <view class="card profile-card">
    <view class="row-title">{{isLoggedIn ? '已通过微信登录' : '登录后保存学习记录'}}</view>
    <view class="row-subtitle">登录后仅用于保存学习记录，不收集手机号和身份信息。</view>
    <button wx:if="{{!isLoggedIn}}" class="primary profile-button" bindtap="login" loading="{{syncing}}" disabled="{{syncing}}">微信一键登录</button>
    <button wx:else class="secondary profile-button" bindtap="sync" loading="{{syncing}}" disabled="{{syncing}}">同步学习记录</button>
  </view>

  <view class="card">
    <view class="section-title">学习资产</view>
    <view class="stats-grid">
      <view class="metric">
        <text class="metric-value">{{total}}</text>
        <text class="metric-label">答题记录</text>
      </view>
      <view class="metric">
        <text class="metric-value">{{wrongCount}}</text>
        <text class="metric-label">错题</text>
      </view>
      <view class="metric">
        <text class="metric-value">{{favoriteCount}}</text>
        <text class="metric-label">收藏</text>
      </view>
      <view class="metric">
        <text class="metric-value">{{entitlement.trialRemaining}}</text>
        <text class="metric-label">解析体验</text>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="section-title">应用信息</view>
    <view class="thin-row" data-page="guide" bindtap="goInfo"><text>使用说明</text><text>查看</text></view>
    <view class="thin-row" data-page="privacy" bindtap="goInfo"><text>隐私说明</text><text>查看</text></view>
    <view class="thin-row" data-page="agreement" bindtap="goInfo"><text>用户协议</text><text>查看</text></view>
    <view class="thin-row" data-page="about" bindtap="goInfo"><text>关于我们</text><text>查看</text></view>
  </view>
</view>
