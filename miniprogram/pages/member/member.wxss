.member-hero {
  padding: 34rpx;
  margin-bottom: 24rpx;
  border-radius: 28rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #00A86B 0%, #31B986 100%);
  box-shadow: 0 18rpx 42rpx rgba(0, 168, 107, 0.22);
}

.hero-title {
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.25;
}

.hero-subtitle {
  margin-top: 14rpx;
  color: rgba(255,255,255,0.9);
  font-size: 25rpx;
  line-height: 1.5;
}

.benefit-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  column-gap: 26rpx;
  row-gap: 16rpx;
  margin-top: 26rpx;
  padding: 22rpx 24rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.12);
  box-sizing: border-box;
}

.benefit-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-height: 38rpx;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 850;
  line-height: 1.2;
  box-sizing: border-box;
}

.benefit-item text {
  width: 10rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 0 0 6rpx rgba(255, 255, 255, 0.14);
  flex: 0 0 auto;
}

.contact-button {
  width: 100%;
  margin-top: 16rpx;
  box-sizing: border-box;
}

.support-card {
  margin-top: 18rpx;
  padding: 24rpx 26rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #F0FBF6 0%, #E6F8EF 100%);
  border: 1rpx solid rgba(0, 168, 107, 0.16);
  box-shadow: 0 8rpx 22rpx rgba(15, 23, 42, 0.04);
}

.support-copy {
  color: #0f766e;
  font-size: 26rpx;
  font-weight: 800;
}

.support-qq {
  margin-top: 8rpx;
  color: #047857;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.45;
}

.support-hint {
  margin-top: 8rpx;
  color: #5b7280;
  font-size: 22rpx;
  line-height: 1.4;
}
