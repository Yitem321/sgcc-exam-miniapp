.home-page {
  padding-top: 18rpx;
}

.home-head {
  align-items: flex-start;
  padding: 22rpx 24rpx;
  margin-bottom: 22rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 12rpx 30rpx rgba(15, 23, 42, 0.06);
}

.home-head .page-title {
  font-size: 46rpx;
  font-weight: 950;
  line-height: 1.1;
  letter-spacing: -1rpx;
}

.dataset-subtitle {
  display: inline-flex;
  align-items: center;
  max-width: 520rpx;
  min-height: 44rpx;
  margin-top: 12rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  color: #0f766e;
  background: #EAF8F2;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 1.2;
  box-sizing: border-box;
}

.mine-entry {
  flex: 0 0 auto;
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  min-height: 54rpx;
  padding: 0 16rpx 0 10rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 900;
  box-sizing: border-box;
  transition: all 0.2s ease;
}

.mine-entry-free {
  color: #0f766e;
  background: #EAF8F2;
}

.mine-entry-vip {
  color: #7c2d12;
  background: linear-gradient(135deg, #fef3c7 0%, #fdba74 100%);
  box-shadow: 0 10rpx 24rpx rgba(217, 119, 6, 0.22);
}

.mine-entry:active {
  opacity: 0.78;
  transform: scale(0.98);
}

.crown-icon {
  width: 36rpx;
  height: 36rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  line-height: 1;
}

.mine-entry-free .crown-icon {
  color: #94a3b8;
  background: #f8fafc;
}

.mine-entry-vip .crown-icon {
  color: #b45309;
  background: rgba(255, 255, 255, 0.7);
}

.home-hero {
  min-height: 290rpx;
  padding: 34rpx;
  margin-bottom: 24rpx;
  border-radius: 28rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #00A86B 0%, #31B986 100%);
  box-shadow: 0 18rpx 42rpx rgba(0, 168, 107, 0.22);
  box-sizing: border-box;
}

.hero-kicker {
  font-size: 24rpx;
  opacity: 0.86;
  margin-bottom: 16rpx;
}

.hero-title {
  font-size: 48rpx;
  font-weight: 800;
  line-height: 1.15;
}

.hero-subtitle {
  margin-top: 12rpx;
  font-size: 25rpx;
  opacity: 0.9;
  line-height: 1.35;
}

.start-button {
  margin-top: 28rpx;
  color: #00A86B;
  background: #ffffff;
}

.home-stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-bottom: 24rpx;
}

.stat-tile {
  padding: 24rpx 12rpx;
  border-radius: 18rpx;
  background: #ffffff;
  text-align: center;
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.05);
}

.stat-tile text:first-child {
  display: block;
  color: #1F2937;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1.1;
}

.stat-tile text:last-child {
  display: block;
  margin-top: 8rpx;
  color: #667085;
  font-size: 22rpx;
}

.quick-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.quick-action {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-height: 132rpx;
  padding: 20rpx;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.05);
  box-sizing: border-box;
}

.quick-action:active {
  opacity: 0.78;
}

.quick-icon {
  width: 58rpx;
  height: 58rpx;
  border-radius: 18rpx;
  background: #EAF8F2;
  position: relative;
}

.quick-icon::before {
  content: "";
  position: absolute;
  left: 16rpx;
  top: 12rpx;
  width: 26rpx;
  height: 32rpx;
  border: 4rpx solid #00A86B;
  border-radius: 6rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.quick-icon::after {
  content: "";
  position: absolute;
  left: 22rpx;
  top: 24rpx;
  width: 14rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: #00A86B;
  box-shadow: 0 10rpx 0 #00A86B;
}

.quick-title {
  font-size: 28rpx;
  font-weight: 800;
}

.quick-sub {
  margin-top: 6rpx;
  color: #667085;
  font-size: 22rpx;
}

.picker-value {
  color: #07865A;
  font-weight: 800;
  max-width: 240rpx;
  text-align: right;
}

.search-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  align-items: flex-end;
  padding: 28rpx;
  background: rgba(15, 23, 42, 0.36);
  box-sizing: border-box;
}

.search-panel {
  width: 100%;
  max-height: 76vh;
  padding: 28rpx;
  border-radius: 22rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.search-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.close-button {
  width: 112rpx;
  height: 56rpx;
  line-height: 56rpx;
  padding: 0;
  border-radius: 12rpx;
  color: #475569;
  font-size: 24rpx;
  background: #f1f5f9;
}

.search-input {
  height: 76rpx;
  padding: 0 24rpx;
  border-radius: 14rpx;
  color: #1F2937;
  background: #F5F7FA;
  box-sizing: border-box;
}

.major-result-list {
  max-height: 540rpx;
  margin-top: 18rpx;
}

.major-result {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  min-height: 78rpx;
  padding: 0 8rpx;
  border-bottom: 1rpx solid #EEF0F2;
  color: #334155;
  font-weight: 600;
  box-sizing: border-box;
}

.major-result-active,
.current-mark {
  color: #07865A;
}

.current-mark {
  flex: 0 0 auto;
  font-size: 22rpx;
}

.empty-result {
  padding: 42rpx 0;
  color: #667085;
  text-align: center;
}

.catalog-error {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  color: #475569;
  line-height: 1.6;
  padding-top: 18rpx;
}

.catalog-error-detail {
  padding: 18rpx;
  border-radius: 12rpx;
  color: #991b1b;
  font-size: 24rpx;
  line-height: 1.5;
  word-break: break-all;
  background: #fef2f2;
}

.retry-button {
  width: 100%;
  box-sizing: border-box;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-top: 22rpx;
  margin-bottom: 12rpx;
}

.metric-link {
  position: relative;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  border: 1rpx solid rgba(0, 168, 107, 0.1);
  background: #F8FFFC;
}

.metric-link:active {
  background: #EAF8F2;
  transform: scale(0.99);
}

.metric-arrow {
  color: #00A86B;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1;
}

.metric-start {
  display: inline-block;
  margin-left: 8rpx;
  color: #00A86B;
  font-size: 22rpx;
  font-weight: 700;
}

.row-arrow {
  color: #98A2B3;
  font-size: 42rpx;
  font-weight: 800;
}

.checkin-card {
  border-left: 6rpx solid #00A86B;
}

.checkin-card .progress-track {
  margin-top: 18rpx;
}

.info-card {
  margin-bottom: 24rpx;
}
