.major-page {
  padding-bottom: 150rpx;
}

.search-input {
  height: 88rpx;
  padding: 0 26rpx;
  margin-bottom: 24rpx;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.05);
  box-sizing: border-box;
}

.current-card {
  border-left: 6rpx solid #00A86B;
}

.major-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  min-height: 104rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #EEF0F2;
}

.major-row:last-child {
  border-bottom: 0;
}

.major-row-active .row-title {
  color: #07865A;
}

.confirm-button {
  width: 100%;
}

.confirm-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 12;
  padding: 18rpx 24rpx 42rpx;
  background: rgba(255, 255, 255, 0.96);
  border-top: 1rpx solid #E5E7EB;
  box-shadow: 0 -10rpx 28rpx rgba(15, 23, 42, 0.08);
  box-sizing: border-box;
}
