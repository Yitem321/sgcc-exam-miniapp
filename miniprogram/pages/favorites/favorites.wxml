<view class="page">
  <view class="card">
    <view class="title">收藏</view>
    <view class="subtle">共 {{list.length}} 题</view>
  </view>

  <button class="primary" wx:if="{{list.length}}" bindtap="practice">重新练习</button>
  <view class="card empty" wx:if="{{!list.length && !loading}}">暂无收藏题</view>

  <view class="card item-card" wx:for="{{list}}" wx:key="id" data-id="{{item.id}}" bindtap="practiceOne">
    <view class="row">
      <text class="tag">{{item.question_type}}</text>
      <text class="subtle">答案 {{item.answer}}</text>
    </view>
    <view class="question">{{index + 1}}. {{item.question}}</view>
  </view>
</view>
